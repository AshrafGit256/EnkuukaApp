@page
@model AccommodationModel
@using EnkuukaApp.Models
@{ ViewData["Title"] = "Accommodation"; ViewData["Page"] = "Accommodation"; }

<div class="phero">
  <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=900&q=80" alt="Accommodation" loading="lazy">
  <div class="phero-ov"></div>
  <div class="phero-content">
    <p class="s-label">Stay & Experience</p>
    <h1 class="s-title f-display">Hospitality at <em>Enkuuka</em></h1>
  </div>
</div>

<div class="ticker"><div class="ticker-track">@foreach(var w in new[]{"Kampala Hotels","Serena Hotel","Sheraton","Pearl of Africa","Book Early","31 December","Kampala Hotels","Serena Hotel","Sheraton","Pearl of Africa","Book Early","31 December"}){<span class="ticker-item">@w<span class="ticker-dot"></span></span>}</div></div>

<div style="background:#F7EEEB;padding:48px 48px 24px">
  <div class="fu">
    <p class="s-label">Where to Stay</p>
    <h2 class="s-title f-display">Kampala's Finest <em>Hotels</em></h2>
    <p class="s-body" style="margin-bottom:28px">Book early — Kampala fills up fast on December 31st. All hotels listed are within 20 minutes of Lubiri Palace.</p>
  </div>
  <div class="fu">
    <div class="hotel-grid">
      @foreach (var hotel in SiteData.Hotels) {
        <div class="hotel-card">
          <img src="@hotel.Img" alt="@hotel.Name" loading="lazy">
          <div class="hotel-body">
            <p class="hotel-stars">@hotel.Stars</p>
            <p class="hotel-name f-display">@hotel.Name</p>
            <p class="hotel-loc">📍 @hotel.Location</p>
            <p class="hotel-price">From @hotel.Price</p>
            <button class="hotel-book">Book Now</button>
          </div>
        </div>
      }
    </div>
  </div>
</div>

<!-- Getting There -->
<div style="background:#EDD8D0;padding:52px 48px;border-top:1px solid rgba(166,124,46,.18)">
  <div class="fu">
    <p class="s-label">Getting There</p>
    <h2 class="s-title f-display">Transport to <em>Lubiri Palace</em></h2>
    <p class="s-body" style="margin-bottom:28px">Lubiri Palace, Mengo, Kampala — all roads lead here on December 31st.</p>
  </div>
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:14px">
    @foreach (var (icon, title, desc) in new[]{
      ("🚌","Festival Shuttle Bus","Free shuttle buses from Kampala city centre every 20 minutes from 7:00 AM"),
      ("🏍","Boda Boda","Dedicated marshaled boda drop-off zones at all three festival gates"),
      ("🚗","Private Vehicle","3 secured parking zones; arrive before 9:00 AM to guarantee a spot"),
      ("📱","Bolt & SafeBoda","Dedicated ride-hail pick-up and drop-off point at the main gate"),
    }) {
      <div style="background:#fff;padding:24px;border:1px solid rgba(166,124,46,.18)">
        <span style="font-size:1.4rem;display:block;margin-bottom:10px">@icon</span>
        <p class="f-display" style="font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:700;color:#1C1A13;margin-bottom:6px">@title</p>
        <p style="font-size:.8rem;color:#7A5252;line-height:1.7">@desc</p>
      </div>
    }
  </div>
</div>

<!-- Tips -->
<div style="background:#1C1A13;padding:52px 48px">
  <div class="fu">
    <p style="font-size:.65rem;letter-spacing:5px;text-transform:uppercase;color:#D45E5E;font-weight:700;margin-bottom:10px">Visitor Tips</p>
    <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(1.6rem,4vw,2.6rem);font-weight:700;color:#FAF5E8;margin-bottom:24px;line-height:1">What to <em style="color:#D45E5E;font-style:italic">Know Before You Go</em></h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px">
      @foreach (var (icon, tip, detail) in new[]{
        ("👗","Dress Code","Traditional Kiganda attire (gomesi & kanzu) is strongly encouraged and celebrated"),
        ("🎟","Tickets","Purchase tickets in advance. Gates open at 9:00 AM; VIP from 8:00 AM"),
        ("💧","Stay Hydrated","Water points are distributed throughout the festival grounds"),
        ("📱","Signal","MTN and Airtel have on-site boosters but expect congestion near midnight"),
        ("🌙","Stay Late","The fireworks at midnight are the climax — plan to stay until 12:15 AM"),
        ("👶","Families","Family zones with child-friendly activities are available near the east gate"),
      }) {
        <div style="background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.12);padding:24px">
          <span style="font-size:1.3rem;display:block;margin-bottom:8px">@icon</span>
          <p style="font-size:.65rem;letter-spacing:2px;text-transform:uppercase;color:#D45E5E;margin-bottom:4px;font-weight:700">@tip</p>
          <p style="font-size:.8rem;color:rgba(250,245,232,.5);line-height:1.7">@detail</p>
        </div>
      }
    </div>
  </div>
</div>
