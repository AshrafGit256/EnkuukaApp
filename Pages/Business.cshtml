@page
@model BusinessModel
@{ ViewData["Title"] = "Business"; ViewData["Page"] = "Business"; }

<div class="phero">
  <img src="https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/trade.png" alt="Business" loading="lazy">
  <div class="phero-ov"></div>
  <div class="phero-content">
    <p class="s-label">Trade Fair & Opportunities</p>
    <h1 class="s-title f-display">Business at <em>Enkuuka</em></h1>
  </div>
</div>

<div class="ticker"><div class="ticker-track">@foreach(var w in new[]{"SME Marketplace","200+ Vendors","Trade Fair","Corporate Expo","NIRA","Blood Donation","MTN","Airtel","Roofings","SME Marketplace","200+ Vendors","Trade Fair","Corporate Expo","NIRA","Blood Donation","MTN","Airtel","Roofings"}){<span class="ticker-item">@w<span class="ticker-dot"></span></span>}</div></div>

<div style="background:#F7EEEB;padding:52px 48px">
  <div class="fu">
    <p class="s-label">Why Exhibit?</p>
    <h2 class="s-title f-display">Uganda's Premier <em>End-of-Year Platform</em></h2>
    <p class="s-body" style="margin-bottom:36px">Enkuuka y'Omwaka connects 50,000 consumers with businesses of every scale — from grassroots vendors to national corporates.</p>
  </div>

  <!-- Tabs -->
  <div class="tab-bar">
    <button class="tab-btn active" data-tab="small">Small Businesses</button>
    <button class="tab-btn" data-tab="trade">Trade Fair</button>
    <button class="tab-btn" data-tab="services">Services</button>
    <button class="tab-btn" data-tab="tourism">Tourism</button>
    <button class="tab-btn" data-tab="transport">Transport</button>
  </div>

  @{
    var bizPanels = new Dictionary<string, (string tag, string title, string desc, string img)[]>{
      ["small"] = new[]{
        ("Food","Fast Food Vendors","Rolex, nyama choma, matoke — street food for thousands.","https://images.unsplash.com/photo-1565299715199-866c917206bb?w=700&q=80"),
        ("Crafts","Handmade Crafts","Bark cloth, jewelry, pottery and bespoke Ugandan fashion.","https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=700&q=80"),
        ("Beverages","Drink Stands","Cold drinks, fresh juices, local brews.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/trade.png"),
        ("Services","Photo Services","Professional portrait and event photography on site.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Cultural_Exhibition.png"),
      },
      ["trade"] = new[]{
        ("Corporate","Corporate Exhibitions","Showcase products to 50,000+ attendees.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Enkkuka_Atmosphere.png"),
        ("SME","SME Marketplace","Curated zone connecting small businesses to buyers.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/trade.png"),
        ("Launch","Product Launches","Announce new products to a massive New Year crowd.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Afrigo_Band.png"),
        ("Networking","B2B Zone","Space for investors and entrepreneurs.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Buganda.png"),
      },
      ["services"] = new[]{
        ("Gov","NIRA Registration","On-site National ID registration for all citizens.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Enkkuka_Atmosphere.png"),
        ("Health","Blood Donation","Uganda Blood Transfusion Services drive.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Cultural_Exhibition.png"),
        ("Telecom","MTN · Airtel","SIM registration, data bundles and mobile money.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/trade.png"),
        ("Medical","Free Health Checks","Immunization, screening and first aid on site.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Buganda.png"),
      },
      ["tourism"] = new[]{
        ("UNESCO","Kasubi Tombs","World Heritage Site — royal tombs of the kings.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Buganda.png"),
        ("Royal","Lubiri Palace Tour","Tour the historic Mengo Palace grounds.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Cultural_Exhibition.png"),
        ("Wildlife","Bwindi Forest","Gorilla trekking packages at the tourism desk.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Maganda.jpeg"),
        ("City","Discover Kampala","Guided tours of Owino Market and the National Museum.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Enkkuka_Atmosphere.png"),
      },
      ["transport"] = new[]{
        ("Shuttle","Festival Shuttle","Buses from city center to Lubiri every 20 minutes.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Enkkuka_Atmosphere.png"),
        ("Boda","Boda Boda Zones","Marshaled boda drop-off inside and outside.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/trade.png"),
        ("Parking","Private Parking","3 parking zones with 24-hour security.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Buganda.png"),
        ("Ride","Bolt & SafeBoda","Dedicated pick-up/drop-off at the main gate.","https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Cultural_Exhibition.png"),
      },
    };
  }

  @foreach (var (key, items) in bizPanels) {
    <div class="biz-panel" data-tab="@key" style="display:@(key=="small"?"grid":"none");grid-template-columns:repeat(2,1fr);gap:14px">
      @foreach (var (tag, title, desc, img) in items) {
        <div class="biz-card">
          <img src="@img" alt="@title" loading="lazy">
          <div class="biz-body">
            <span class="biz-tag">@tag</span>
            <p class="biz-title f-display">@title</p>
            <p class="biz-desc">@desc</p>
            <span class="biz-cta">Register Now →</span>
          </div>
        </div>
      }
    </div>
  }
</div>

<!-- Vendor Packages -->
<div style="background:#EDD8D0;padding:52px 48px;border-top:1px solid rgba(166,124,46,.18)">
  <div class="fu">
    <p class="s-label">Vendor Packages</p>
    <h2 class="s-title f-display">Choose Your <em>Space</em></h2>
  </div>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:28px">
    @foreach (var (tier, price, features, highlight) in new[]{
      ("Standard Stall","UGX 150,000",new[]{"3×3m space","1 table + 2 chairs","Festival directory listing","Basic signage"},"Most Popular"),
      ("Premium Booth","UGX 350,000",new[]{"5×5m branded booth","Power connection","Social media feature","Premium location"},"Best Value"),
      ("Corporate Pavilion","UGX 1,200,000",new[]{"10×10m fully branded","Dedicated staff support","Stage announcement","VIP passes (×10)"},""),
    }) {
      <div style="background:#fff;padding:32px;border:1px solid rgba(166,124,46,.18);position:relative">
        @if (!string.IsNullOrEmpty(highlight)) {
          <div style="position:absolute;top:16px;right:16px;background:#A62E2E;color:#fff;font-size:.55rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:4px 10px">@highlight</div>
        }
        <p class="f-block" style="font-size:.65rem;letter-spacing:3px;color:#A62E2E;margin-bottom:8px">@tier</p>
        <p class="f-display" style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:700;color:#1C1A13;margin-bottom:16px">@price</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:20px">
          @foreach (var f in features) {
            <li style="font-size:.82rem;color:#7A5252;display:flex;align-items:center;gap:8px"><span style="color:#A62E2E">✓</span> @f</li>
          }
        </ul>
        <a href="/Contact" class="btn-red" style="width:100%;text-align:center;display:block">Book Now</a>
      </div>
    }
  </div>
</div>
