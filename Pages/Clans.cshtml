@page
@model ClansModel
@using EnkuukaApp.Models
@{ ViewData["Title"] = "Clans"; ViewData["Page"] = "Clans"; }

<div class="phero">
  <img src="https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Clans.png" alt="Clans" loading="lazy">
  <div class="phero-ov"></div>
  <div class="phero-content">
    <p class="s-label">Ebika by'Obuganda</p>
    <h1 class="s-title f-display">The 52 Clans of <em>Buganda</em></h1>
  </div>
</div>

<div class="ticker">
  <div class="ticker-track">
    @foreach (var w in new[]{"52 Clans","Ebika","Omuziro","Totem","Clan System","Patrilineal","Buganda Heritage","52 Clans","Ebika","Omuziro","Totem","Clan System","Patrilineal","Buganda Heritage"}) {
      <span class="ticker-item">@w<span class="ticker-dot"></span></span>
    }
  </div>
</div>

<div class="clans-section">
  <div class="clans-header">
    <div class="fu">
      <p class="s-label">About the Clan System</p>
      <h2 class="s-title f-display">Identity Through <em>Blood & Totem</em></h2>
      <p style="font-size:.88rem;color:#7A5252;line-height:1.9;margin-top:12px">Every Muganda must belong to one of Buganda's clans (<em>Ebika</em>). Membership is patrilineal — passed from father to child. Each clan is identified by a primary totem (<strong>Omuziro</strong>) and secondary totem (<strong>Akabbiro</strong>).</p>
    </div>
    <div class="fu">
      <div class="clan-filter-bar">
        <div class="clan-search-wrap">
          <span style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#7A5252;font-size:.9rem;pointer-events:none">⌕</span>
          <input id="clanSearch" class="clan-search" placeholder="Search by clan, totem, or head…">
        </div>
        <div class="clan-filter-pills">
          <button class="clan-filter-pill active" data-filter="All">All</button>
          <button class="clan-filter-pill" data-filter="Original 5">Original 5</button>
          <button class="clan-filter-pill" data-filter="Royal">Royal</button>
          <button class="clan-filter-pill" data-filter="Other">Other</button>
        </div>
      </div>
    </div>
  </div>

  <div class="fu">
    <div class="clans-grid-pro">
      @{ int ci = 0; }
      @foreach (var clan in SiteData.Clans) {
        <div class="clan-card-pro" data-name="@clan.Name.ToLower()" data-totem="@clan.Totem.ToLower()" data-head="@clan.Head.ToLower()" data-orig="@clan.IsOriginal.ToString().ToLower()" data-royal="@clan.IsRoyal.ToString().ToLower()">
          <img class="clan-img" src="@clan.Img" alt="@clan.Totem" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1549366021-9f761d450615?w=640&q=80'">
          <div class="clan-gradient"></div>
          <div class="clan-badge">
            <span class="clan-badge-pill clan-badge-num">@((ci+1).ToString("D2"))</span>
            @if (clan.IsOriginal) { <span class="clan-badge-pill clan-badge-orig">Banansangwa</span> }
            @if (clan.IsRoyal) { <span class="clan-badge-pill clan-badge-royal">👑 Royal</span> }
          </div>
          <div class="clan-static-bottom">
            <span class="clan-card-totem-label">Totem</span>
            <p class="clan-card-name f-display">@clan.Name</p>
            <p class="clan-card-totem">@clan.Totem</p>
          </div>
          <div class="clan-hover-panel">
            <span class="clan-card-totem-label">Ekika · Clan @((ci+1).ToString("D2"))</span>
            <p class="clan-card-name f-display">@clan.Name</p>
            <p class="clan-card-totem" style="color:rgba(250,245,232,.65);font-size:.78rem;line-height:1.5">Omuziro: <strong style="color:#D45E5E">@clan.Totem</strong></p>
            <div class="clan-head-row">
              <div class="clan-head-icon">♛</div>
              <div>
                <span class="clan-head-label">Clan Head</span>
                <p class="clan-head-name">@clan.Head</p>
              </div>
            </div>
          </div>
        </div>
        ci++;
      }
    </div>
    <div class="clan-count-bar">
      <p class="clan-count">Showing <strong style="color:#A62E2E" id="clanCount">@SiteData.Clans.Count</strong> of @SiteData.Clans.Count clans</p>
      <div class="clan-legend">
        <div class="clan-legend-item"><div class="clan-legend-dot" style="background:#A62E2E"></div><span>Banansangwa</span></div>
        <div class="clan-legend-item"><div class="clan-legend-dot" style="background:#7A1515"></div><span>Royal</span></div>
      </div>
    </div>
  </div>

  <div style="margin-top:40px;display:grid;grid-template-columns:repeat(3,1fr);gap:2px">
    @foreach (var (icon, title, body) in new[]{ ("🪶","Patrilineal Heritage","Clan membership passes exclusively through the father."), ("🚫","Clan Exogamy","Marriage between members of the same clan is strictly forbidden."), ("🐾","The Sacred Totem","Members never eat, hunt, or harm their clan's totem.") }) {
      <div style="padding:32px 36px;border-right:1px solid rgba(166,124,46,.10);background:#fff">
        <div style="font-size:1.6rem;margin-bottom:12px">@icon</div>
        <p class="f-display" style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:700;color:#1C1A13;margin-bottom:8px">@title</p>
        <p style="font-size:.8rem;color:#7A5252;line-height:1.85">@body</p>
      </div>
    }
  </div>
</div>
