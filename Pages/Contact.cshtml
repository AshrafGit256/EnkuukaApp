@page
@model ContactModel
@{ ViewData["Title"] = "Contact"; ViewData["Page"] = "Contact"; }

<div class="phero">
  <img src="https://raw.githubusercontent.com/AshrafGit256/enkuuka-site/main/public/assets/images/Buganda.png" alt="Contact" loading="lazy">
  <div class="phero-ov"></div>
  <div class="phero-content">
    <p class="s-label">Reach Out</p>
    <h1 class="s-title f-display">Contact <em>Us</em></h1>
  </div>
</div>

<div class="ticker"><div class="ticker-track">@foreach(var w in new[]{"Get in Touch","info@enkuuka.ug","+256 414 000 000","Lubiri Palace Mengo","Vendor Inquiries","Sponsorships","Media Partnerships","Get in Touch","info@enkuuka.ug","+256 414 000 000","Lubiri Palace Mengo","Vendor Inquiries","Sponsorships","Media Partnerships"}){<span class="ticker-item">@w<span class="ticker-dot"></span></span>}</div></div>

<div style="background:#F7EEEB">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:0">
    <!-- Info column -->
    <div style="padding:52px 48px">
      <div class="fu">
        <p class="s-label">Get in Touch</p>
        <h2 class="s-title f-display">We'd Love to <em>Hear from You</em></h2>
        <p class="s-body" style="margin-bottom:32px">For vendor inquiries, sponsorships, media partnerships or general information about Enkuuka y'Omwaka.</p>
        <div style="display:flex;flex-direction:column;gap:18px;margin-bottom:36px">
          @foreach (var (icon, label, val) in new[]{
            ("📍","Location","Lubiri Palace, Mengo, Kampala, Uganda"),
            ("📞","Phone","+256 414 000 000"),
            ("✉","Email","info@enkuuka.ug"),
            ("🕒","Office Hours","Mon–Fri, 9:00 AM – 5:00 PM EAT"),
          }) {
            <div style="display:flex;gap:14px;align-items:flex-start">
              <span style="font-size:.95rem;margin-top:2px">@icon</span>
              <div>
                <p style="font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:#A62E2E;margin-bottom:1px">@label</p>
                <p style="font-size:.85rem;color:#7A5252">@val</p>
              </div>
            </div>
          }
        </div>

        <!-- Enquiry types -->
        <p class="s-label">Enquiry Types</p>
        <div style="display:flex;flex-direction:column;gap:2px;margin-top:12px">
          @foreach (var (icon, type, email) in new[]{
            ("🏪","Vendor / Trade Fair","vendors@enkuuka.ug"),
            ("🤝","Sponsorship","sponsors@enkuuka.ug"),
            ("📺","Media / Press","media@enkuuka.ug"),
            ("🎟","Tickets","tickets@enkuuka.ug"),
          }) {
            <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:#EDD8D0;border-bottom:1px solid rgba(166,124,46,.10)">
              <span style="font-size:.82rem;color:#1C1A13;display:flex;align-items:center;gap:8px">@icon @type</span>
              <span style="font-size:.75rem;color:#A62E2E;font-weight:600">@email</span>
            </div>
          }
        </div>
      </div>
    </div>

    <!-- Form column -->
    <div style="padding:52px 48px;background:#EDD8D0;border-left:1px solid rgba(166,124,46,.10)">
      <div class="fu">
        <div id="contactForm">
          <p class="f-display" style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;color:#1C1A13;margin-bottom:22px">Send a Message</p>
          <input class="contact-input" placeholder="Your full name" id="cName">
          <input class="contact-input" placeholder="Email address" id="cEmail" type="email">
          <select class="contact-input" id="cSubject" style="cursor:pointer;appearance:auto">
            <option value="" disabled selected>Select enquiry type…</option>
            <option>Vendor / Trade Fair Booking</option>
            <option>Sponsorship Enquiry</option>
            <option>Media / Press Pass</option>
            <option>Ticket Purchase</option>
            <option>General Information</option>
          </select>
          <textarea class="contact-input" rows="5" placeholder="Your message…" id="cMsg"></textarea>
          <button id="contactSubmit" class="btn-red" style="width:100%">Send Message →</button>
        </div>
        <div id="contactSuccess" style="display:none;text-align:center;padding:48px 20px">
          <div style="font-size:2.5rem;margin-bottom:16px">✅</div>
          <p class="f-display" style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;color:#A62E2E;margin-bottom:8px">Message Sent!</p>
          <p style="color:#7A5252;font-size:.85rem;margin-bottom:22px">We'll get back to you within 24 hours.</p>
          <button id="contactReset" class="btn-outline">Send Another</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Map placeholder -->
<div style="background:#1C1A13;padding:52px 48px;text-align:center">
  <div class="fu">
    <p style="font-size:.65rem;letter-spacing:5px;text-transform:uppercase;color:#D45E5E;font-weight:700;margin-bottom:10px">Find Us</p>
    <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(1.6rem,4vw,2.4rem);font-weight:700;color:#FAF5E8;margin-bottom:24px;line-height:1">Lubiri Palace, <em style="color:#D45E5E;font-style:italic">Mengo</em></h2>
    <div style="background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.12);padding:40px;max-width:560px;margin:0 auto">
      <p style="font-size:2rem;margin-bottom:12px">📍</p>
      <p style="font-size:.85rem;color:rgba(250,245,232,.5);line-height:1.8">Lubiri Palace · Mengo<br>Kampala, Uganda<br><br>Coordinates: 0.3136° N, 32.5601° E</p>
      <div style="margin-top:20px">
        <a href="https://maps.google.com/?q=Lubiri+Palace+Mengo+Kampala" target="_blank" class="btn-red" style="font-size:.65rem">Open in Google Maps →</a>
      </div>
    </div>
  </div>
</div>
